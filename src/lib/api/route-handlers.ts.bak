import dayjs from 'dayjs'
import { db } from '@/lib/database/db'
import type { WorkoutSetInput } from '@/lib/database/index'
import { workoutQueries, workoutSetQueries } from '@/lib/database/index'
import { getProgressQueries } from '@/lib/database/queries'
import type {
  CalendarDataResponse,
  WorkoutSet as CalendarWorkoutSet,
  WorkoutCalendarData,
  WorkoutDetailResponse,
} from '@/lib/types/calendar'
import type { WorkoutSet } from '@/lib/types/database'
import type { ProgressRequest, ProgressResponse } from '@/lib/types/progress'
import {
  calculateAverageWorkoutsPerWeek,
  calculateCurrentStreak,
  calculateLongestStreak,
  formatCalendarDate,
  getRolling30DayRange,
  getWorkoutsThisMonth,
} from '@/lib/utils/calendar'

const jsonHeaders = { 'Content-Type': 'application/json' }

export function jsonResponse<T>(body: T, init: ResponseInit = {}): Response {
  const headers = new Headers(init.headers)
  headers.set('Content-Type', jsonHeaders['Content-Type'])

  return new Response(JSON.stringify(body), {
    ...init,
    headers,
  })
}

export function errorDetails(error: unknown): string {
  return error instanceof Error ? error.message : 'Unknown error'
}

export function buildCalendarDataResponse({
  userId,
  startDateParam,
  endDateParam,
}: {
  userId: string
  startDateParam: string | null
  endDateParam: string | null
}): CalendarDataResponse {
  const dateRange =
    startDateParam && endDateParam
      ? {
          start: new Date(startDateParam),
          end: new Date(endDateParam),
          startISOString: startDateParam,
          endISOString: endDateParam,
        }
      : getRolling30DayRange()

  const sessions = workoutQueries.getSessionsByDateRange(
    userId,
    dateRange.startISOString.split('T')[0],
    dateRange.endISOString.split('T')[0],
  )

  const allSets: WorkoutSet[] = []
  for (const session of sessions) {
    allSets.push(...workoutSetQueries.getByWorkoutId(session.id))
  }

  const workoutDataMap = new Map<string, WorkoutCalendarData>()

  sessions.forEach((session) => {
    const dateKey = formatCalendarDate(session.date)
    const sessionSets = allSets.filter((set) => set.workout_id === session.id)
    const totalVolume = sessionSets.reduce(
      (sum, set) => sum + (set.weight || 0) * (set.reps || 0),
      0,
    )
    const exerciseCount = new Set(sessionSets.map((set) => set.exercise_id)).size
    const existing = workoutDataMap.get(dateKey)

    if (existing) {
      existing.workoutCount += 1
      existing.totalSets += sessionSets.length
      existing.totalVolume += totalVolume
      existing.exerciseCount += exerciseCount
      existing.sessionIds.push(session.id)
      return
    }

    let intensity: 'light' | 'moderate' | 'intense' = 'light'
    if (sessionSets.length >= 15 || totalVolume >= 5000) {
      intensity = 'intense'
    } else if (sessionSets.length >= 8 || totalVolume >= 2500) {
      intensity = 'moderate'
    }

    workoutDataMap.set(dateKey, {
      date: dateKey,
      hasWorkout: true,
      workoutCount: 1,
      totalSets: sessionSets.length,
      totalVolume,
      exerciseCount,
      sessionIds: [session.id],
      intensity,
      duration:
        session.end_time && session.start_time
          ? Math.round(
              (new Date(session.end_time).getTime() - new Date(session.start_time).getTime()) /
                (1000 * 60),
            )
          : undefined,
    })
  })

  const workoutData: WorkoutCalendarData[] = []
  const currentDate = new Date(dateRange.start)
  const endDate = new Date(dateRange.end)

  while (currentDate <= endDate) {
    const dateKey = formatCalendarDate(currentDate)
    workoutData.push(
      workoutDataMap.get(dateKey) ?? {
        date: dateKey,
        hasWorkout: false,
        workoutCount: 0,
        totalSets: 0,
        totalVolume: 0,
        exerciseCount: 0,
        sessionIds: [],
        intensity: 'light',
      },
    )
    currentDate.setDate(currentDate.getDate() + 1)
  }

  const allUserSessions = workoutQueries.getRecentSessions(userId, 365)
  const workoutDates = allUserSessions.map((s) => s.date)

  return {
    success: true,
    data: workoutData,
    summary: {
      totalWorkouts: sessions.length,
      totalVolume: Array.from(workoutDataMap.values()).reduce(
        (sum, day) => sum + day.totalVolume,
        0,
      ),
      averageWorkoutsPerWeek: calculateAverageWorkoutsPerWeek(workoutDates),
      longestStreak: calculateLongestStreak(workoutDates),
      currentStreak: calculateCurrentStreak(workoutDates),
      lastWorkoutDate: workoutDates.length > 0 ? workoutDates[0] : null,
      workoutsThisMonth: getWorkoutsThisMonth(workoutDates),
    },
    dateRange: {
      start: dateRange.startISOString,
      end: dateRange.endISOString,
    },
  }
}

export function calendarDataFailureResponse(): CalendarDataResponse {
  return {
    success: false,
    error: 'Failed to get calendar data',
    data: [],
    summary: {
      totalWorkouts: 0,
      totalVolume: 0,
      averageWorkoutsPerWeek: 0,
      longestStreak: 0,
      currentStreak: 0,
      lastWorkoutDate: null,
      workoutsThisMonth: 0,
    },
    dateRange: {
      start: new Date().toISOString(),
      end: new Date().toISOString(),
    },
  }
}

export function buildWorkoutDetailsResponse(userId: string, date: string): WorkoutDetailResponse {
  const sessions = workoutQueries.getSessionsByDateRange(userId, date, date)

  return {
    success: true,
    data: sessions.map((session) => {
      const sessionWithDetails = workoutQueries.getSessionWithDetails(session.id)

      if (!sessionWithDetails) {
        return {
          id: session.id,
          name: session.name,
          userId: session.user_id,
          date: session.date,
          duration:
            session.end_time && session.start_time
              ? Math.round(
                  (new Date(session.end_time).getTime() - new Date(session.start_time).getTime()) /
                    (1000 * 60),
                )
              : undefined,
          notes: session.notes,
          sets: [],
          totalVolume: 0,
          exerciseCount: 0,
        }
      }

      const allMappedSets: CalendarWorkoutSet[] = []
      let totalVolume = 0

      for (const group of sessionWithDetails.exercises) {
        for (const set of group.sets) {
          allMappedSets.push({
            id: set.id,
            sessionId: set.workout_id,
            exerciseId: set.exercise_id,
            setNumber: set.set_number,
            reps: set.reps || 0,
            weight: set.weight || 0,
            restTime: set.rest_time,
            notes: set.notes,
            exerciseName: group.exercise.name,
          })
          totalVolume += (set.weight || 0) * (set.reps || 0)
        }
      }

      return {
        id: sessionWithDetails.id,
        name: sessionWithDetails.name,
        userId: sessionWithDetails.user_id,
        date: sessionWithDetails.date,
        duration:
          sessionWithDetails.end_time && sessionWithDetails.start_time
            ? Math.round(
                (new Date(sessionWithDetails.end_time).getTime() -
                  new Date(sessionWithDetails.start_time).getTime()) /
                  (1000 * 60),
              )
            : undefined,
        notes: sessionWithDetails.notes,
        sets: allMappedSets,
        totalVolume,
        exerciseCount: sessionWithDetails.exercises.length,
      }
    }),
  }
}

export function buildProgressResponse(progressRequest: ProgressRequest): ProgressResponse {
  const progressData = getProgressQueries(db).getProgressData(progressRequest)

  return {
    success: true,
    data: {
      progress: progressData,
      totalExercises: progressData.length,
      dateRange: {
        start: progressRequest.startDate,
        end: progressRequest.endDate,
      },
    },
  }
}

export function defaultProgressDateRange(): Pick<ProgressRequest, 'startDate' | 'endDate'> {
  return {
    startDate: dayjs().subtract(90, 'day').format('YYYY-MM-DD'),
    endDate: dayjs().format('YYYY-MM-DD'),
  }
}

export function validateWorkoutSetInput(data: WorkoutSetInput): string | null {
  if (data.workout_id && data.exercise_id && data.set_order) {
    return null
  }

  return 'Missing required fields: workout_id, exercise_id, and set_order are required'
}
