import { describe, expect, it } from 'vitest'
import {
  buildNormalizedExerciseDataset,
  normalizeExerciseRecord,
  splitInstructionText,
} from './exercise-dataset'

describe('exercise dataset normalization', () => {
  it('normalizes an upstream exercise into the local seed shape', () => {
    const result = normalizeExerciseRecord({
      id: '0001',
      name: '3/4 sit-up',
      category: 'waist',
      body_part: 'waist',
      equipment: 'body weight',
      instructions: {
        en: 'Lie down. Curl up. Lower with control.',
      },
      muscle_group: 'hip flexors',
      secondary_muscles: ['hip flexors', 'lower back'],
      target: 'abs',
      image: 'images/0001-demo.jpg',
      gif_url: 'videos/0001-demo.gif',
    })

    expect(result).not.toBeNull()
    expect(result?.category).toEqual({
      id: 'waist',
      name: 'Waist',
      description: 'Waist exercises from the synced exercise dataset',
    })
    expect(result?.exercise).toEqual({
      id: '0001',
      name: '3/4 sit-up',
      category_id: 'waist',
      equipment: 'body weight',
      primary_muscles: ['abs'],
      secondary_muscles: ['hip flexors', 'lower back'],
      instructions: ['Lie down.', 'Curl up.', 'Lower with control.'],
      gif_path: 'gifs/0001-demo.gif',
      preview_image_path: 'previews/0001-demo.jpg',
    })
  })

  it('builds category and exercise lists while skipping malformed rows', () => {
    const dataset = buildNormalizedExerciseDataset([
      {
        id: '0001',
        name: '3/4 sit-up',
        category: 'waist',
        equipment: 'body weight',
        instructions: { en: 'Lie down.' },
        target: 'abs',
      },
      {
        id: '',
        name: '',
        category: 'waist',
        equipment: 'body weight',
      },
      {
        id: '0002',
        name: 'barbell curl',
        category: 'upper arms',
        equipment: 'barbell',
        instructions: { en: 'Stand tall.' },
        target: 'biceps',
      },
    ])

    expect(dataset.categories.map((category) => category.id)).toEqual(['upper-arms', 'waist'])
    expect(dataset.exercises).toHaveLength(2)
    expect(dataset.warnings).toHaveLength(1)
  })

  it('splits instruction text into stable display steps', () => {
    expect(splitInstructionText('Brace your core. Drive through your heels. Stand tall.')).toEqual([
      'Brace your core.',
      'Drive through your heels.',
      'Stand tall.',
    ])
  })
})
