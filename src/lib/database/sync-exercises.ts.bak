import { mkdir, readFile, rm, writeFile } from 'node:fs/promises'
import { dirname, join, resolve } from 'node:path'
import { fileURLToPath } from 'node:url'
import {
  buildNormalizedExerciseDataset,
  EXERCISE_DATASET_BASE_URL,
  EXERCISE_DATASET_JSON_URL,
  EXERCISE_DATASET_REPO,
  type ExerciseDatasetManifest,
  type UpstreamExerciseDatasetExercise,
} from './exercise-dataset'

const __filename = fileURLToPath(import.meta.url)
const __dirname = dirname(__filename)

const dataDir = join(__dirname, 'data')
const projectRoot = resolve(__dirname, '../../..')
const exerciseMediaRoot = join(projectRoot, 'public', 'images', 'exercises')
const upstreamCachePath = join(dataDir, 'exercises.upstream.json')
const normalizedExercisesPath = join(dataDir, 'exercises.json')
const normalizedCategoriesPath = join(dataDir, 'exercise-categories.json')
const manifestPath = join(dataDir, 'exercises-manifest.json')

const DEFAULT_CONCURRENCY = 8

async function fetchJson<T>(url: string): Promise<T> {
  const response = await fetch(url, {
    headers: {
      Accept: 'application/json',
      'User-Agent': 'Gymmie Exercise Sync',
    },
  })

  if (!response.ok) {
    throw new Error(`Failed to fetch ${url}: ${response.status} ${response.statusText}`)
  }

  return (await response.json()) as T
}

async function downloadFile(url: string, destinationPath: string): Promise<void> {
  const response = await fetch(url, {
    headers: {
      Accept: '*/*',
      'User-Agent': 'Gymmie Exercise Sync',
    },
  })

  if (!response.ok) {
    throw new Error(`Failed to download ${url}: ${response.status} ${response.statusText}`)
  }

  const arrayBuffer = await response.arrayBuffer()
  await writeFile(destinationPath, Buffer.from(arrayBuffer))
}

async function runWithConcurrency<T>(
  items: T[],
  worker: (item: T, index: number) => Promise<void>,
  concurrency: number,
): Promise<void> {
  let currentIndex = 0

  const workers = Array.from({ length: Math.max(1, concurrency) }, async () => {
    while (currentIndex < items.length) {
      const index = currentIndex
      currentIndex += 1
      await worker(items[index], index)
    }
  })

  await Promise.all(workers)
}

async function main(): Promise<void> {
  console.log(`Syncing exercises from ${EXERCISE_DATASET_REPO}...`)

  const upstreamExercises =
    await fetchJson<UpstreamExerciseDatasetExercise[]>(EXERCISE_DATASET_JSON_URL)
  const normalized = buildNormalizedExerciseDataset(upstreamExercises)

  await mkdir(dataDir, { recursive: true })
  await mkdir(exerciseMediaRoot, { recursive: true })
  await rm(join(exerciseMediaRoot, 'gifs'), { recursive: true, force: true })
  await rm(join(exerciseMediaRoot, 'previews'), {
    recursive: true,
    force: true,
  })
  await mkdir(join(exerciseMediaRoot, 'gifs'), { recursive: true })
  await mkdir(join(exerciseMediaRoot, 'previews'), { recursive: true })

  const mediaQueue = normalized.exercises.flatMap((exercise) => {
    const downloads: Array<{ sourcePath: string; destinationPath: string }> = []

    if (exercise.gif_path) {
      downloads.push({
        sourcePath: `videos/${exercise.gif_path.split('/').pop()}`,
        destinationPath: join(exerciseMediaRoot, exercise.gif_path),
      })
    }

    if (exercise.preview_image_path) {
      downloads.push({
        sourcePath: `images/${exercise.preview_image_path.split('/').pop()}`,
        destinationPath: join(exerciseMediaRoot, exercise.preview_image_path),
      })
    }

    return downloads
  })

  let downloadedCount = 0
  let failedCount = 0
  const warnings = [...normalized.warnings]

  await runWithConcurrency(
    mediaQueue,
    async (media, index) => {
      const sourceUrl = `${EXERCISE_DATASET_BASE_URL}/${media.sourcePath}`

      try {
        await downloadFile(sourceUrl, media.destinationPath)
        downloadedCount += 1

        if ((index + 1) % 100 === 0 || index === mediaQueue.length - 1) {
          console.log(`Downloaded ${index + 1}/${mediaQueue.length} media files`)
        }
      } catch (error) {
        failedCount += 1
        warnings.push(
          `Failed to download ${media.sourcePath}: ${error instanceof Error ? error.message : String(error)}`,
        )
      }
    },
    DEFAULT_CONCURRENCY,
  )

  const manifest: ExerciseDatasetManifest = {
    source_repo: EXERCISE_DATASET_REPO,
    source_json_url: EXERCISE_DATASET_JSON_URL,
    synced_at: new Date().toISOString(),
    upstream_exercise_count: upstreamExercises.length,
    normalized_exercise_count: normalized.exercises.length,
    category_count: normalized.categories.length,
    skipped_records: normalized.warnings.length,
    media_downloaded: downloadedCount,
    media_failed: failedCount,
    warnings,
  }

  await writeFile(upstreamCachePath, JSON.stringify(upstreamExercises, null, 2))
  await writeFile(normalizedExercisesPath, JSON.stringify(normalized.exercises, null, 2))
  await writeFile(normalizedCategoriesPath, JSON.stringify(normalized.categories, null, 2))
  await writeFile(manifestPath, JSON.stringify(manifest, null, 2))

  console.log(
    `Synced ${normalized.exercises.length} exercises across ${normalized.categories.length} categories`,
  )
  console.log(`Media downloaded: ${downloadedCount}, failed: ${failedCount}`)
}

main().catch(async (error) => {
  const existingManifest = await readFile(manifestPath, 'utf-8').catch(() => null)
  if (existingManifest) {
    console.error('Exercise sync failed, existing cache has been left in place.')
  }

  console.error(error)
  process.exit(1)
})
