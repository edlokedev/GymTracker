import { describe, expect, it } from 'vitest'
import type { ProgressDataPoint } from '../../types/progress'
import {
  buildExerciseProgress,
  calculateMetricTrend,
  calculateStatistics,
  markPersonalRecords,
} from './progress'

const makePoint = (id: string, overrides: Partial<ProgressDataPoint> = {}): ProgressDataPoint => ({
  id,
  date: '2026-01-01',
  exerciseId: 'bench-press',
  exerciseName: 'Bench Press',
  weight: 100,
  reps: 5,
  volume: 500,
  isPersonalRecord: false,
  sessionId: 'session-1',
  setNumber: 1,
  ...overrides,
})

describe('progress query math', () => {
  it('returns empty statistics for no progress data', () => {
    expect(calculateStatistics([])).toEqual({
      totalWorkouts: 0,
      averageWeight: null,
      averageReps: null,
      totalVolume: 0,
      improvementPercentage: 0,
    })
  })

  it('treats single point and near-even series as stable trends', () => {
    expect(calculateMetricTrend([500])).toBe('stable')
    expect(calculateMetricTrend([100, 102, 101, 103])).toBe('stable')
  })

  it('detects upward and downward trends', () => {
    expect(calculateMetricTrend([100, 105, 130, 140])).toBe('up')
    expect(calculateMetricTrend([140, 130, 105, 100])).toBe('down')
  })

  it('does not divide by zero when the first volume is zero', () => {
    const statistics = calculateStatistics([
      makePoint('set-1', { volume: 0, weight: 0 }),
      makePoint('set-2', { date: '2026-01-02', volume: 500 }),
    ])

    expect(statistics.improvementPercentage).toBe(0)
    expect(Number.isFinite(statistics.improvementPercentage)).toBe(true)
  })

  it('marks chronological weight, reps, and volume personal records', () => {
    const { markedDataPoints, personalRecords } = markPersonalRecords([
      makePoint('set-2', {
        date: '2026-01-02',
        setNumber: 1,
        weight: 105,
        reps: 5,
        volume: 525,
      }),
      makePoint('set-1', {
        date: '2026-01-01',
        setNumber: 1,
        weight: 100,
        reps: 5,
        volume: 500,
      }),
      makePoint('set-3', {
        date: '2026-01-03',
        setNumber: 1,
        weight: 105,
        reps: 6,
        volume: 630,
      }),
    ])

    expect(markedDataPoints.map((point) => point.id)).toEqual(['set-1', 'set-2', 'set-3'])
    expect(markedDataPoints.map((point) => point.isPersonalRecord)).toEqual([true, true, true])
    expect(personalRecords.maxWeight?.id).toBe('set-2')
    expect(personalRecords.maxReps?.id).toBe('set-3')
    expect(personalRecords.maxVolume?.id).toBe('set-3')
  })

  it('builds exercise progress with PRs, statistics, and trend data', () => {
    const progress = buildExerciseProgress('bench-press', [
      makePoint('set-1', { date: '2026-01-01', volume: 500 }),
      makePoint('set-2', {
        date: '2026-01-02',
        weight: 120,
        reps: 5,
        volume: 600,
      }),
    ])

    expect(progress.exerciseName).toBe('Bench Press')
    expect(progress.personalRecords.maxVolume?.id).toBe('set-2')
    expect(progress.statistics.totalWorkouts).toBe(2)
    expect(progress.statistics.improvementPercentage).toBe(20)
    expect(progress.trends.volume).toBe('up')
  })
})
