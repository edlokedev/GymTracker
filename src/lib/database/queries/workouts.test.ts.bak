import { mkdtempSync, rmSync } from 'node:fs'
import { tmpdir } from 'node:os'
import { join } from 'node:path'
import { afterEach, describe, expect, it, vi } from 'vitest'

describe('workout queries', () => {
  const tempDirs: string[] = []
  const openManagers: Array<{ close: () => void }> = []

  afterEach(() => {
    for (const manager of openManagers.splice(0)) {
      manager.close()
    }

    vi.resetModules()
    delete process.env.DB_DIR
    delete process.env.GYMTRACKER_SKIP_AUTO_SEED

    for (const dir of tempDirs.splice(0)) {
      rmSync(dir, { recursive: true, force: true })
    }
  })

  it('removes workout sets when deleting a session even without sqlite cascades', async () => {
    const tempDir = mkdtempSync(join(tmpdir(), 'gymtracker-workouts-db-'))
    tempDirs.push(tempDir)

    process.env.DB_DIR = tempDir
    process.env.NODE_ENV = 'test'
    process.env.GYMTRACKER_SKIP_AUTO_SEED = '1'

    const { DatabaseManager, db } = await import('../db')
    openManagers.push(DatabaseManager)
    const { workoutQueries, workoutSetQueries } = await import('./workouts')

    db.prepare(`
      INSERT INTO user (id, username, email)
      VALUES (?, ?, ?)
    `).run('user-1', 'test_user', 'test@example.com')

    db.prepare(`
      INSERT INTO exercise_categories (id, name, description)
      VALUES (?, ?, ?)
    `).run('strength', 'Strength', 'Strength training')

    db.prepare(`
      INSERT INTO exercises (id, name, category_id, equipment, primary_muscles)
      VALUES (?, ?, ?, ?, ?)
    `).run('bench-press', 'Bench Press', 'strength', 'barbell', JSON.stringify(['chest']))

    const session = workoutQueries.createSession({
      user_id: 'user-1',
      name: 'Push Day',
      date: '2026-04-27',
      start_time: '2026-04-27T10:00:00.000Z',
    })

    workoutSetQueries.createSet({
      workout_id: session.id,
      exercise_id: 'bench-press',
      set_order: 1,
      reps: 8,
      weight: 100,
    })

    expect(workoutSetQueries.getByWorkoutId(session.id)).toHaveLength(1)

    db.pragma('foreign_keys = OFF')

    expect(workoutQueries.deleteSession(session.id)).toBe(true)
    expect(workoutQueries.getSession(session.id)).toBeNull()
    expect(workoutSetQueries.getByWorkoutId(session.id)).toEqual([])
  })
})
