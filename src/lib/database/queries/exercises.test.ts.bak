import { mkdtempSync, rmSync } from 'node:fs'
import { tmpdir } from 'node:os'
import { join } from 'node:path'
import { afterEach, describe, expect, it, vi } from 'vitest'

describe('exercise queries', () => {
  const tempDirs: string[] = []
  const openManagers: Array<{ close: () => void }> = []

  afterEach(() => {
    for (const manager of openManagers.splice(0)) {
      manager.close()
    }

    vi.resetModules()
    delete process.env.DB_DIR
    delete process.env.GYMTRACKER_SKIP_AUTO_SEED

    for (const dir of tempDirs.splice(0)) {
      rmSync(dir, { recursive: true, force: true })
    }
  })

  it('reports more exercises when search results exceed the requested page size', async () => {
    const tempDir = mkdtempSync(join(tmpdir(), 'gymtracker-exercises-db-'))
    tempDirs.push(tempDir)

    process.env.DB_DIR = tempDir
    process.env.NODE_ENV = 'test'
    process.env.GYMTRACKER_SKIP_AUTO_SEED = '1'

    const { DatabaseManager, db } = await import('../db')
    openManagers.push(DatabaseManager)
    const { exerciseQueries } = await import('./exercises')

    db.prepare(`
      INSERT INTO exercise_categories (id, name, description)
      VALUES (?, ?, ?)
    `).run('strength', 'Strength', 'Strength training')

    const insertExercise = db.prepare(`
      INSERT INTO exercises (id, name, category_id, equipment, primary_muscles, secondary_muscles, instructions)
      VALUES (?, ?, ?, ?, ?, ?, ?)
    `)

    for (let index = 1; index <= 21; index += 1) {
      insertExercise.run(
        `movement-${index.toString().padStart(2, '0')}`,
        `Movement ${index.toString().padStart(2, '0')}`,
        'strength',
        'body weight',
        JSON.stringify(['chest']),
        JSON.stringify([]),
        JSON.stringify(['Move with control.']),
      )
    }

    const firstPage = exerciseQueries.search({ limit: 20, offset: 0 })
    const secondPage = exerciseQueries.search({ limit: 20, offset: 20 })

    expect(firstPage.data).toHaveLength(20)
    expect(firstPage.total).toBe(21)
    expect(firstPage.hasMore).toBe(true)
    expect(secondPage.data).toHaveLength(1)
    expect(secondPage.total).toBe(21)
    expect(secondPage.hasMore).toBe(false)
  })

  it('combines multiple selected filters with OR within each facet and AND across facets', async () => {
    const tempDir = mkdtempSync(join(tmpdir(), 'gymtracker-exercises-db-'))
    tempDirs.push(tempDir)

    process.env.DB_DIR = tempDir
    process.env.NODE_ENV = 'test'
    process.env.GYMTRACKER_SKIP_AUTO_SEED = '1'

    const { DatabaseManager, db } = await import('../db')
    openManagers.push(DatabaseManager)
    const { exerciseQueries } = await import('./exercises')

    const insertCategory = db.prepare(`
      INSERT INTO exercise_categories (id, name, description)
      VALUES (?, ?, ?)
    `)
    insertCategory.run('strength', 'Strength', 'Strength training')
    insertCategory.run('cardio', 'Cardio', 'Cardio training')
    insertCategory.run('mobility', 'Mobility', 'Mobility training')

    const insertExercise = db.prepare(`
      INSERT INTO exercises (id, name, category_id, equipment, primary_muscles, secondary_muscles, instructions)
      VALUES (?, ?, ?, ?, ?, ?, ?)
    `)
    const addExercise = (
      id: string,
      name: string,
      categoryId: string,
      equipment: string,
      primaryMuscles: string[],
      secondaryMuscles: string[] = [],
    ) => {
      insertExercise.run(
        id,
        name,
        categoryId,
        equipment,
        JSON.stringify(primaryMuscles),
        JSON.stringify(secondaryMuscles),
        JSON.stringify(['Move with control.']),
      )
    }

    addExercise('barbell-bench', 'Barbell Bench Press', 'strength', 'barbell', ['chest'])
    addExercise('dumbbell-row', 'Dumbbell Row', 'strength', 'dumbbell', ['lats'])
    addExercise('treadmill-run', 'Treadmill Run', 'cardio', 'machine', ['quadriceps'])
    addExercise('mobility-flow', 'Mobility Flow', 'mobility', 'body weight', ['shoulders'])
    addExercise('cable-fly', 'Cable Fly', 'strength', 'cable', ['chest'])

    const categoryUnion = exerciseQueries.search({
      category_ids: ['strength', 'cardio'],
      limit: 10,
    })
    expect(categoryUnion.data.map((exercise) => exercise.id)).toEqual([
      'barbell-bench',
      'cable-fly',
      'dumbbell-row',
      'treadmill-run',
    ])

    const muscleUnion = exerciseQueries.search({
      muscle_groups: ['chest', 'lats'],
      limit: 10,
    })
    expect(muscleUnion.data.map((exercise) => exercise.id)).toEqual([
      'barbell-bench',
      'cable-fly',
      'dumbbell-row',
    ])

    const intersectedFacets = exerciseQueries.search({
      category_ids: ['strength', 'cardio'],
      equipment_values: ['barbell', 'machine'],
      muscle_groups: ['chest', 'quadriceps'],
      limit: 10,
    })
    expect(intersectedFacets.data.map((exercise) => exercise.id)).toEqual([
      'barbell-bench',
      'treadmill-run',
    ])

    const paginated = exerciseQueries.search({
      category_ids: ['strength'],
      limit: 2,
      offset: 0,
    })
    expect(paginated.total).toBe(3)
    expect(paginated.hasMore).toBe(true)
  })
})
