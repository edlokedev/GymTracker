# --- Supabase: server-side ---
# Project URL + API keys from the Supabase dashboard (Settings → API Keys).
# Supabase moved to a new key naming convention in 2026:
#   * Publishable key (sb_publishable_…) — replaces the legacy anon JWT.
#     Safe to ship to the browser.
#   * Secret key (sb_secret_…) — replaces the legacy service_role JWT.
#     Bypasses RLS, never expose to the browser.
# The legacy env-var names (SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY) are
# still accepted as fallbacks by src/lib/env.ts so migrations stay cheap.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Supabase: browser ---
# Inlined into the client bundle by Vite. Same publishable-key value as above.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Public site origin used to build the OAuth redirect URL
# (`${VITE_SITE_URL}/auth/callback`). In dev this can be left unset — the
# SupabaseAuthProvider falls back to window.location.origin.
# Example: https://gymtracker.vercel.app
VITE_SITE_URL=

# --- Build target ---
# Set to `vercel` on Vercel so the TanStack Start Nitro plugin emits the
# `.vercel/output` directory. Leave unset locally to keep the default
# node-server build.
SERVER_PRESET=

# --- Legacy Better Auth (still required until parity is reached) ---
# These power the existing src/lib/auth/config.ts. Will be removed once the
# SupabaseAuthProvider is wired in and the Better Auth routes are deleted.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=

# --- Legacy SQLite ---
# Path to the local SQLite file used by Better Auth. All API routes already
# read from Supabase Postgres — better-sqlite3 is only loaded by the Better
# Auth handler at src/routes/api/auth/$.ts. Will not load on Vercel (native
# module). Stays until the SupabaseAuthProvider swap is verified and the
# Better Auth handler is deleted.
DATABASE_URL=file:./database.sqlite

# --- Misc ---
NODE_ENV=development
